# Copy this file to .env and fill in real values. Never commit the real .env.

PORT=5000

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=philsar_db
# Set to "true" for managed hosts that require SSL (e.g. Railway)
DB_SSL=false

# Google Gemini API key (used for chatbot + DSS guidance generation)
GEMINI_API_KEY=

JWT_SECRET=

# Production only — the deployed frontend's URL, used to lock down CORS
FRONTEND_URL=
# Production only — this backend's own public URL, used to build uploaded-file links
# when Cloudinary isn't configured (see below)
BACKEND_URL=

# Optional — when all three are set, uploaded images (module covers, avatars,
# certificate backgrounds) go to Cloudinary instead of local disk. Required in
# production on platforms with an ephemeral filesystem (e.g. Railway), since anything
# written to local disk there is lost on every redeploy. Get these from your
# Cloudinary dashboard's "Product Environment Credentials" section.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
